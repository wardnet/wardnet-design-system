{
  "name": "@wardnet/brand",
  "version": "0.1.0",
  "description": "Wardnet brand kit — logo/icon/mark SVG vectors (text source + outlined dist), brand fonts, and the on-demand PNG rasterizer",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wardnet/wardnet-design-system.git",
    "directory": "packages/brand"
  },
  "homepage": "https://github.com/wardnet/wardnet-design-system/tree/main/packages/brand#readme",
  "bin": {
    "wardnet-brand-png": "assets/tools/build-png.js"
  },
  "exports": {
    "./svg/*": "./assets/dist/*",
    "./svg-src/*": "./assets/src/*",
    "./fonts/*": "./assets/fonts/*",
    "./guide.html": "./guide.html",
    "./guide.css": "./guide.css",
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "guide.html",
    "guide.css",
    "README.md"
  ],
  "scripts": {
    "build": "node assets/tools/build-svg.js"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "@xmldom/xmldom": "^0.9.7",
    "opentype.js": "^1.3.4"
  }
}
