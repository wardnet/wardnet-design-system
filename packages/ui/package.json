{
  "name": "@wardnet/ui",
  "version": "0.1.1",
  "description": "Wardnet design system — domain-agnostic React primitives and brand components, documented in Storybook",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wardnet/wardnet-design-system.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/wardnet/wardnet-design-system/tree/main/packages/ui#readme",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/ui.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@wardnet/styles": "workspace:^",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "radix-ui": "1.5.0",
    "sonner": "2.0.7"
  },
  "peerDependencies": {
    "lucide-react": ">=1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-mcp": "0.6.0",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "4.3.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@wardnet/brand": "workspace:^",
    "lucide-react": "1.17.0",
    "prettier": "3.8.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-dts": "5.0.2"
  }
}
