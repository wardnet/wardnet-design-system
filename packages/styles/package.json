{
  "name": "@wardnet/styles",
  "version": "0.1.0",
  "description": "Wardnet web design language — CSS tokens, themes, and component classes",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wardnet/wardnet-design-system.git",
    "directory": "packages/styles"
  },
  "homepage": "https://github.com/wardnet/wardnet-design-system/tree/main/packages/styles#readme",
  "exports": {
    ".": "./styles.css",
    "./styles.css": "./styles.css",
    "./theme.css": "./theme.css",
    "./typography.css": "./typography.css",
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    }
  },
  "files": [
    "dist",
    "src",
    "styles.css",
    "theme.css",
    "typography.css"
  ],
  "dependencies": {
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  }
}
