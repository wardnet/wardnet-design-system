{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "generated/**"]
    },
    "@wardnet/brand#build": {
      "outputs": ["assets/dist/**"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "format:check": {},
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    }
  }
}
