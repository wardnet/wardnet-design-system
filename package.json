{
  "name": "wardnet-design-system",
  "private": true,
  "packageManager": "yarn@4.17.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,md,json}\"",
    "build-storybook": "turbo run build-storybook",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "yarn workspaces foreach --all --no-private --topological npm publish --tolerate-republish"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.11",
    "prettier": "3.8.4",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  }
}
